# ── Build stage ───────────────────────────────────────────────────────────────
FROM golang:1.24-alpine AS builder
ENV GOTOOLCHAIN=auto

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -ldflags="-s -w" -trimpath -o ssh-cli ./cmd/ssh

# ── Final stage ───────────────────────────────────────────────────────────────
FROM alpine:3.19

RUN apk add --no-cache ca-certificates tzdata \
    && addgroup -S app \
    && adduser  -S app -G app

WORKDIR /app

COPY --from=builder /build/ssh-cli ./ssh-cli

RUN mkdir -p /data && chown -R app:app /app /data
USER app

EXPOSE 2223
ENTRYPOINT ["./ssh-cli"]
