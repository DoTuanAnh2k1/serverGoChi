# ── Build stage ───────────────────────────────────────────────────────────────
FROM golang:1.24-alpine AS builder
ENV GOTOOLCHAIN=auto

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -ldflags="-s -w" -trimpath -o /tmp/frontend ./cmd/frontend/main.go

# ── Final stage ───────────────────────────────────────────────────────────────
FROM alpine:3.19

RUN apk add --no-cache ca-certificates curl \
    && addgroup -S app && adduser -S app -G app

WORKDIR /app
COPY --from=builder /tmp/frontend       ./frontend
COPY --from=builder /build/web/index.html ./web/index.html

RUN chown -R app:app /app
USER app

EXPOSE 8080

HEALTHCHECK --interval=15s --timeout=5s --start-period=5s --retries=3 \
    CMD curl -sf http://127.0.0.1:${FRONTEND_PORT:-8080}/ || exit 1

ENTRYPOINT ["./frontend"]
