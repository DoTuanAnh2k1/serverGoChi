# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Database
DB_DRIVER=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=secret
MYSQL_DB_NAME=mgt_db

# Logging
LOG_LEVEL=info
DB_LOG_LEVEL=warn

# JWT — change SECRET_KEY in production
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRY_HOURS=24

# CORS (allow all by default, restrict in production)
CORS_ORIGINS=*
CORS_METHODS=GET,POST,DELETE,PUT,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# Router
ROUTER_BASE_PATH=/aa

# Swagger spec path (default: api.yaml in working directory)
API_SPEC_PATH=api.yaml

# ────────────────────────────────────────────────
# Leader Election (Kubernetes Lease API)
# ────────────────────────────────────────────────
# Enable leader election (requires K8s namespace)
LEADER_ELECTION_ENABLED=false

# K8s Lease resource name — must be unique within namespace
LEASE_LOCK_NAME=mgt-service-leader

# Namespace for Lease resource (use pod's namespace)
LEASE_LOCK_NAMESPACE=default

# Pod identity (use downward API: metadata.name)
POD_NAME=mgt-service-pod-0

# Lease duration before another pod can take over (seconds, default 15)
LEASE_DURATION_SECONDS=15

# Deadline for leader to renew lease (seconds, default 10)
RENEW_DEADLINE_SECONDS=10

# Retry period for acquiring/renewing lease (seconds, default 2)
RETRY_PERIOD_SECONDS=2

# ────────────────────────────────────────────────
# Leader Tasks — runs only on leader pod
# ────────────────────────────────────────────────
# CSV export directory; mount PVC here in K8s
CSV_EXPORT_DIR=/data/csv

# Daily export hour (0-23, default 23 = 23:00)
CSV_EXPORT_HOUR=23
