# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Database
DB_DRIVER=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=secret
MYSQL_DB_NAME=mgt_db

# Logging
LOG_LEVEL=info
DB_LOG_LEVEL=warn

# JWT — bắt buộc đổi SECRET_KEY trong production
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRY_HOURS=24

# CORS (mặc định cho phép tất cả, thu hẹp lại trong production)
CORS_ORIGINS=*
CORS_METHODS=GET,POST,DELETE,PUT,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# Router
ROUTER_BASE_PATH=/aa

# Swagger spec path (mặc định: api.yaml trong working directory)
API_SPEC_PATH=api.yaml

# ────────────────────────────────────────────────
# Leader Election (Kubernetes Lease API)
# ────────────────────────────────────────────────
# Bật leader election (cần chạy trong K8s namespace)
LEADER_ELECTION_ENABLED=false

# Tên Lease resource trên K8s — phải unique trong namespace
LEASE_LOCK_NAME=mgt-service-leader

# Namespace chứa Lease resource (nên để pod's namespace)
# Trong K8s dùng downward API: valueFrom.fieldRef.fieldPath: metadata.namespace
LEASE_LOCK_NAMESPACE=default

# Identity của pod này — dùng để nhận diện leader
# Trong K8s dùng downward API: valueFrom.fieldRef.fieldPath: metadata.name
POD_NAME=mgt-service-pod-0

# Thời gian giữ lease trước khi pod khác có thể chiếm (giây, default 15)
LEASE_DURATION_SECONDS=15

# Deadline leader phải renew lease; nếu không renew kịp sẽ mất lease (giây, default 10)
RENEW_DEADLINE_SECONDS=10

# Chu kỳ thử acquire / renew lease (giây, default 2)
RETRY_PERIOD_SECONDS=2

# ────────────────────────────────────────────────
# Leader Tasks — chỉ chạy trên pod leader
# ────────────────────────────────────────────────
# Thư mục lưu file CSV; mount PVC vào đây trong K8s
CSV_EXPORT_DIR=/data/csv

# Giờ chạy export hàng ngày (0-23, default 23 = 23:00)
CSV_EXPORT_HOUR=23
